{
  "name": "ci-automated-tests-demo",
  "version": "1.0.0",
  "description": "Continuous Integration Pipeline with Automated Tests Demo",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "jest",
    "test:ci": "jest --ci --coverage --reporters=default --reporters=jest-junit",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ tests/",
    "security-check": "npm audit --audit-level=high"
  },
  "dependencies": {
    "applicationinsights": "^2.9.6",
    "express": "^4.19.2",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "coverageThreshold": {
      "global": {
        "branches": 90,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    },
    "coverageReporters": [
      "text",
      "lcov",
      "cobertura",
      "html"
    ]
  }
}
